{
  "name": "setup-imagemagick",
  "version": "8.0.0",
  "description": "GitHub action to setup imagemagick",
  "main": "lib/index.js",
  "scripts": {
    "all": "pnpm run lint && pnpm run test && pnpm run build && pnpm run package",
    "build": "tsc",
    "fix": "prettier --write **/*.{ts,json,md}",
    "lint": "prettier --check **/*.{ts,json,md}",
    "package": "ncc build --license licenses.txt",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mfinelli/setup-imagemagick.git"
  },
  "keywords": [
    "imagemagick"
  ],
  "author": "Mario Finelli",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/mfinelli/setup-imagemagick/issues"
  },
  "homepage": "https://github.com/mfinelli/setup-imagemagick#readme",
  "dependencies": {
    "@actions/cache": "^5.1.0",
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/io": "^2.0.0",
    "@actions/tool-cache": "^2.0.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@vercel/ncc": "^0.44.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
